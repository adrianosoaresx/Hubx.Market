# Django
DJANGO_ENV=development
SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
PAYMENTS_WEBHOOK_TOKEN=change-me-webhook-token
PAYMENTS_OBSERVABILITY_TOKEN=change-me-observability-token
PAYMENTS_PROVIDER_DEFAULT=asaas
PAYMENTS_REAL_PROVIDER_ROLLOUT_MODE=sandbox
PAYMENTS_REAL_PROVIDER_ENABLED_TENANTS=
PAYMENTS_REAL_PROVIDER_FALLBACK_MODE=lite
ASAAS_API_KEY=
ASAAS_SANDBOX=1
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=
ASAAS_HTTP_TIMEOUT_SECONDS=15
SUBSCRIPTIONS_BILLING_PROVIDER_DEFAULT=asaas
PAGARME_API_BASE_URL=https://api.pagar.me/core/v5
PAGARME_SECRET_KEY=
PAGARME_API_KEY=
PAGARME_WEBHOOK_SIGNATURE_HEADER=X-Hub-Signature
PAGARME_HTTP_TIMEOUT_SECONDS=15

# Assistant
ASSISTANT_LLM_ENABLED=0
ASSISTANT_LLM_PROVIDER=openai-compatible
ASSISTANT_LLM_MODEL=gpt-4o-mini
ASSISTANT_LLM_API_KEY=
ASSISTANT_LLM_TIMEOUT_SECONDS=8
ASSISTANT_LLM_BASE_URL=https://api.openai.com/v1

# Database (production)
DB_NAME=hubx
DB_USER=hubx
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
